{
    "id": "scene02",
    
    "name": "seconde scène",
    
    "background": "assets/scenes/cave002.png",
    
    "objects": [
        {
            "id": "keybox01",
            
            "image": "assets/sprites/keybox01.png",
            
            "x": 50,
            "y": 50,
            
            "width": 5,
            "height": 5,
            
            "visible": true,
            
            "actions":[
                {
                "type": "condition",
                
                "input": {
                            "type": "popup",
                            "title": "Boîte à clé",
                            "text": "Entrez le code.",
                            "placeholder": "Code",
                            "button": "Valider"
                },

                "condition": {
                            "type": "equals",
                            "value": "4268"
                },

                "onSuccess": [

                    {
                        "type": "inventoryAdd",
                        "item": "key"
                    },

                    {
                        "type": "popup",
                        "title": "Succès",
                        "text": "Vous trouvez une petite clé.",
                        "image": "assets/sprites/key01.png"
                    },

                    {
                        "type": "returnToHost",
                        "result": "keyFound"
                    }

                ],

                "onFailure": [
                    {
                      "type": "popup",
                      "title": "Échec",
                      "text": "Le code est incorrect."
                    }
                  ]
                }
                
            ]
        },

         {
            "id": "paper01",
            
            "image": "assets/sprites/paper01.png",
            
            "x": 15,
            "y": 70,
            
            "width": 5,
            "height": 5,
            
            "visible": true,
            
            "actions":[
                {
                    "type": "popup",
                    "title": "Document froissé",
                    "text": "4268 est inscrit sur le papier."
                }
            ]
        },

        {
            "id":"safe01",

            "image": "assets/sprites/safe01.png",
            
            "x": 70,
            "y": 20,
            
            "width": 10,
            "height": 10,
            
            "visible": true,
            
            "actions":[

                {

                    "type":"condition",

                    "condition":{

                        "type":"inventory",

                        "item":"key"

                    },

                    "onSuccess":[

                        {
                            "type":"inventoryAdd",

                            "item":"jewels"
                        },

                        {
                            "type":"popup",

                            "title":"Coffre",

                            "text":"Vous ouvrez le coffre et récupérez les joyaux.",

                            "image":"assets/sprites/jewels01.png"
                        },

                        {
                            "type":"returnToHost",

                            "result":"jewelsFound"
                        }

                    ],

                    "onFailure":[

                        {

                            "type":"popup",

                            "title":"Le coffre",

                            "text":"Cette serrure nécessite une clé."

                        }

                    ]

                }

            ]

        }
    ]
}
